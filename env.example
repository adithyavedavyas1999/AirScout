# AirScout Environment Variables
# ==============================
# Copy this file to .env and fill in your values

# Supabase Database Connection
SUPABASE_DB_HOST=db.xxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-database-password

# Supabase API (for frontend)
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Chicago Data Portal App Token (optional, increases rate limit)
# Get one at: https://data.cityofchicago.org/profile/edit/developer_settings
CHICAGO_DATA_APP_TOKEN=

# EPA AirNow API Key (for AQI data)
# Get one at: https://docs.airnowapi.org/account/request/
AIRNOW_API_KEY=

# OpenWeatherMap API Key (for wind-adjusted scoring)
# Get one at: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# VAPID Keys (for Web Push notifications)
# Generate with: python scripts/generate_vapid_keys.py
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@airscout.app
